---
// About — the personal close. A balanced split: the portrait carries the left
// half, the bio sits beside it under a short display headline. Prose set in
// Spectral, the one long-form serif moment on the site.
import { withBase } from '../lib/url';
const portrait = '/andrew-portrait.webp';
const headline = 'An Irishman in Berlin.';
const paragraphs = [
  'Ten years into a career that started in industrial design and found its home in digital. I took the long route, and I think it shows in how I approach problems.',
  'I like being early: close to the team, asking the questions that should have been asked sooner, and getting everyone aligned on what we’re actually building before the design work begins.',
  'Away from screens I’m usually behind a camera or training for some goal I’ve set myself. Persistently optimistic about both.',
];
---

<section id="about" class="about column--wide">
  <p class="eyebrow about__label">About</p>

  <div class="about__grid">
    <div class="about__portrait">
      <img src={withBase(portrait)} alt="Andrew Malone" loading="lazy" />
    </div>
    <div class="about__bio">
      <h3 class="about__headline">{headline}</h3>
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: var(--section);
  }
  .about__label {
    margin-bottom: var(--space-2xl);
  }

  /* Photo and bio as equal partners, centred against each other. */
  .about__grid {
    display: grid;
    grid-template-columns: minmax(0, 30rem) 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .about__portrait {
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
  }
  .about__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about__headline {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    margin-bottom: var(--space-lg);
  }

  .about__bio {
    max-width: 46ch;
  }
  .about__bio p {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.1rem + 0.5vw, 1.5rem);
    line-height: 1.5;
    letter-spacing: var(--tracking-tight);
    color: var(--color-ink);
    text-wrap: pretty;
  }
  .about__bio p + p {
    margin-top: var(--space-md);
  }

  @media (max-width: 48rem) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .about__portrait {
      max-width: 22rem;
    }
  }
</style>
