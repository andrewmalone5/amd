---
// About — the personal close. The one place on the site where Spectral runs as
// reading-length prose, so the most human section reads like a signed note
// rather than body copy. Full-ink: this is her voice. Copy is the persona
// verbatim.
const bio =
  'A Nigerian designer in Lisbon, a decade into a career that started in print and drifted into product. I do my best work early, close to the problem, before anyone’s opened a design tool. Off-hours I’m usually running or failing to keep plants alive. Cautiously optimistic about both.';
---

<section id="about" class="about column--wide">
  <p class="eyebrow about__label">About</p>
  <p class="about__bio">{bio}</p>
</section>

<style>
  .about {
    padding-block: var(--section-loose);
    border-top: 1px solid var(--color-hairline);
  }
  .about__label {
    margin-bottom: var(--space-2xl);
  }

  .about__bio {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1.15rem + 0.9vw, 1.75rem);
    line-height: 1.42;
    letter-spacing: var(--tracking-tight);
    color: var(--color-ink);
    max-width: 34ch; /* intimate measure — reads as a personal note, not a column */
    text-wrap: pretty;
  }
</style>
