---
// Site footer = the contact moment. Button is styled to the ink palette
// rather than LinkedIn-blue to stay in the system.
const linkedin = 'https://www.linkedin.com/in/andrewmalonedesign/';
const year = 2026;

interface Props {
  /** True on case-study pages: just the meta line, no contact CTA. */
  minimal?: boolean;
}
const { minimal = false } = Astro.props;
---

<footer id={minimal ? undefined : 'contact'} class:list={['site-footer', { 'site-footer--minimal': minimal }]}>
  <div class="site-footer__inner">
    {!minimal && (
      <>
        <p class="site-footer__cta">Get in touch.</p>
        <p class="site-footer__body">
          I care about working on things that leave people better off. If that&rsquo;s
          what you&rsquo;re building, I&rsquo;d love to talk.
        </p>

        <a class="site-footer__link" href={linkedin} target="_blank" rel="noopener">Connect on LinkedIn<span class="site-footer__arrow" aria-hidden="true">&nbsp;&rarr;</span></a>
      </>
    )}

    <div class="site-footer__meta">
      <span>Berlin, Germany</span>
      <span aria-hidden="true">/</span>
      <span>&copy; {year} Andrew Malone</span>
    </div>
  </div>
</footer>

<style>
  .site-footer--minimal {
    border-top: 1px solid var(--color-hairline);
  }

  /* Centred close, echoing the display treatment of the hero. */
  .site-footer__inner {
    width: 100%;
    max-width: var(--width-wide);
    margin-inline: auto;
    padding: var(--section) var(--page-gutter) var(--space-xl);
    text-align: center;
  }

  .site-footer__cta {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    margin-bottom: var(--space-lg);
  }

  .site-footer__body {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink-muted);
    max-width: 44ch;
    margin-inline: auto;
  }

  /* The contact link speaks the site's own affordance language — the same
     underlined line-with-arrow as every case-study link, one size up. */
  .site-footer__link {
    display: inline-block;
    margin-top: var(--space-xl);
    font-size: var(--text-lead);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-hairline-strong);
    padding-bottom: 3px;
    transition: border-color var(--duration) var(--ease-out);
  }
  .site-footer__arrow {
    display: inline-block;
    transition: transform var(--duration) var(--ease-out);
  }
  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    border-bottom-color: var(--color-ink);
  }
  .site-footer__link:hover .site-footer__arrow,
  .site-footer__link:focus-visible .site-footer__arrow {
    transform: translateX(4px);
  }

  .site-footer__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-xs);
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .site-footer__meta [aria-hidden] { display: none; }

  /* Case-study pages keep the quiet left-aligned meta line. */
  .site-footer--minimal .site-footer__inner { text-align: left; }
  .site-footer--minimal .site-footer__meta {
    border-top: 0;
    padding-top: 0;
    justify-content: flex-start;
  }
  .site-footer--minimal .site-footer__meta [aria-hidden] { display: inline; }

  /* Minimal variant (case-study pages): the meta line alone, quiet. */
  .site-footer--minimal .site-footer__inner {
    padding-block: var(--space-xl);
  }
  .site-footer--minimal .site-footer__meta {
    margin-top: 0;
  }
</style>
