---
// Site header. Quiet by default — transparent over the paper — with a single
// hairline that fades in on scroll. Links resolve to home anchors so they work
// from inside a case study too. Wordmark stays in Hanken; the serif is saved
// for display moments.
import { withBase } from '../lib/url';

const wordmark = 'Andrew Malone';
const home = withBase('/');
const links = [
  { label: 'Work', href: withBase('/#work') },
  { label: 'About', href: withBase('/#about') },
  { label: 'Contact', href: withBase('/#contact') },
];
---

<header class="site-header" data-header>
  <div class="site-header__inner">
    <a class="wordmark" href={home}>{wordmark}</a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    {/* Style preview: flips Editorial ↔ Oakly Editorial while a keeper is
        chosen. Remove this button (and the alternate block in tokens.css)
        once decided. */}
    <button class="style-toggle" type="button" data-style-toggle>
      <span class="style-toggle__label" aria-hidden="true">Style</span>
      <span data-style-name>Editorial</span>
    </button>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <span class="nav-toggle__bars" aria-hidden="true"><span></span><span></span></span>
    </button>
  </div>

  <nav id="mobile-nav" class="nav-mobile" aria-label="Primary (mobile)">
    <a class="nav-mobile__wordmark" href={home}>{wordmark}</a>
    <button class="nav-mobile__close" type="button" aria-label="Close menu">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M6 6l14 14M20 6L6 20"/></svg>
    </button>
    <ul>
      {links.map((l, i) => (
        <li style={`--i: ${i}`}><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }

  /* Fades in once the page is scrolled — no blur, no glass, just paper + a rule. */
  .site-header.is-scrolled {
    background: var(--color-paper);
    border-bottom-color: var(--color-hairline);
  }

  .site-header__inner {
    width: 100%;
    max-width: var(--width-wide);
    margin-inline: auto;
    padding: var(--space-sm) var(--page-gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .wordmark {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: var(--weight-semibold);
    letter-spacing: -0.01em;
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* Desktop nav ---------------------------------------------------------- */
  .nav-desktop ul {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
  }
  .nav-desktop a {
    position: relative;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }
  /* Hairline underline that draws in from the left on hover. */
  .nav-desktop a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.35em;
    width: 100%;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration) var(--ease-out);
  }
  .nav-desktop a:hover { color: var(--color-ink); }
  .nav-desktop a:hover::after { transform: scaleX(1); }

  /* Style preview toggle ---------------------------------------------------- */
  .style-toggle {
    background: none;
    border: 1px solid var(--color-hairline-strong);
    padding: 0.35em 0.8em;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    white-space: nowrap;
    transition: border-color var(--duration-fast) var(--ease-out);
  }
  .style-toggle:hover { border-color: var(--color-ink); }
  .style-toggle__label {
    color: var(--color-ink-faint);
    margin-right: 0.5em;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: 0.6875rem;
  }

  /* Mobile toggle — a two-bar hamburger. ---------------------------------- */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: var(--space-2xs);
    margin-right: calc(-1 * var(--space-2xs));
    cursor: pointer;
    color: var(--color-ink);
  }
  .nav-toggle__bars {
    display: block;
    width: 26px;
  }
  .nav-toggle__bars span {
    display: block;
    height: 1.6px;
    background: currentColor;
    border-radius: 2px;
  }
  .nav-toggle__bars span + span { margin-top: 6px; }

  /* Mobile panel — full-viewport overlay. -------------------------------- */
  .nav-mobile {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--color-paper);
    padding: var(--space-sm) var(--page-gutter) var(--space-2xl);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration) var(--ease-out);
  }
  .nav-mobile a.nav-mobile__wordmark {
    position: absolute;
    top: var(--space-sm);
    left: var(--page-gutter);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: var(--weight-semibold);
    letter-spacing: -0.01em;
    color: var(--color-ink);
    line-height: 3.4rem;
  }
  .nav-mobile__close {
    position: absolute;
    top: var(--space-sm);
    right: calc(var(--page-gutter) - var(--space-2xs));
    padding: var(--space-2xs);
    background: none;
    border: 0;
    color: var(--color-ink);
    cursor: pointer;
    line-height: 0;
  }
  .nav-mobile ul {
    list-style: none;
    padding: 0;
    margin: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-lg);
  }
  .nav-mobile li {
    opacity: 0;
    transform: translateY(0.75rem);
  }
  .nav-mobile a {
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    line-height: 1.1;
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
  }

  /* Below the breakpoint: swap desktop nav for the toggle + overlay. */
  @media (max-width: 48rem) {
    .nav-desktop { display: none; }
    .nav-toggle { display: inline-flex; align-items: center; }
    /* The style toggle keeps working on mobile, tucked beside the burger. */
    .style-toggle { margin-left: auto; }
    .style-toggle__label { display: none; }
    .nav-mobile { display: block; }
    .site-header.nav-open .nav-mobile {
      opacity: 1;
      pointer-events: auto;
    }
    /* Links rise in, staggered, once the overlay is open. */
    .site-header.nav-open .nav-mobile li {
      opacity: 1;
      transform: translateY(0);
      transition:
        opacity var(--duration-slow) var(--ease-out),
        transform var(--duration-slow) var(--ease-out);
      transition-delay: calc(120ms + var(--i) * 70ms);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile li { opacity: 1; transform: none; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const close = document.querySelector<HTMLButtonElement>('.nav-mobile__close');
  const panel = document.getElementById('mobile-nav');

  // Hairline fades in once the page moves.
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const setOpen = (open: boolean) => {
    const wasOpen = header?.classList.contains('nav-open') ?? false;
    header?.classList.toggle('nav-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
    // Keyboard users land inside the overlay on open and back on the
    // toggle on close, instead of tabbing through the page behind it.
    if (open) close?.focus();
    else if (wasOpen) toggle?.focus();
  };

  toggle?.addEventListener('click', () => setOpen(true));
  close?.addEventListener('click', () => setOpen(false));

  // Close after choosing a destination.
  panel?.querySelectorAll('a:not(.nav-mobile__wordmark)').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );

  // Escape closes the overlay.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  // Style preview: flip Editorial ↔ Oakly Editorial. The pre-paint script in
  // the head applies the saved choice; this button only advances and persists it.
  const STYLES = ['editorial', 'oakly'] as const;
  const NAMES: Record<string, string> = { editorial: 'Editorial', oakly: 'Oakly Editorial' };
  const styleBtn = document.querySelector<HTMLButtonElement>('[data-style-toggle]');
  const styleName = document.querySelector<HTMLElement>('[data-style-name]');

  const currentStyle = () => document.documentElement.dataset.style ?? 'editorial';
  const applyStyle = (s: string) => {
    if (s === 'editorial') delete document.documentElement.dataset.style;
    else document.documentElement.dataset.style = s;
    if (styleName) styleName.textContent = NAMES[s];
    styleBtn?.setAttribute('aria-label', `Switch site style, current: ${NAMES[s]}`);
    try { localStorage.setItem('amd-style', s); } catch {}
  };

  applyStyle(currentStyle()); // sync the label with the pre-paint choice
  styleBtn?.addEventListener('click', () => {
    const next = STYLES[(STYLES.indexOf(currentStyle() as (typeof STYLES)[number]) + 1) % STYLES.length];
    applyStyle(next);
  });

  // Close if the viewport grows past the mobile breakpoint.
  window.matchMedia('(min-width: 48rem)').addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>
