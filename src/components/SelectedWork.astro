---
// Selected Work — image-led alternating rows. The image is the hero: a large
// 4:3 frame taking most of the row, with the story beside it in a narrower
// column, sides alternating per project. Whole row is one link.
import { projects } from '../data/projects';
import { withBase } from '../lib/url';
import { imgDims } from '../lib/img';

const featured = projects.filter((p) => !p.secondary);
const other = projects.filter((p) => p.secondary);
---

<section id="work" class="selected-work column--wide">
  <h2 class="ghost-head selected-work__label">Selected Work</h2>

  <ol class="work-list">
    {featured.map((p) => (
      <li>
        <a class="work" href={withBase(`/work/${p.slug}`)}>
          <div class="work__media">
            {p.image ? (
              <img src={withBase(p.image)} alt={p.title} loading="lazy" decoding="async" {...imgDims(p.image)} />
            ) : (
              <div class="work__media-ph"><span>Project image</span></div>
            )}
          </div>

          <div class="work__body">
            <span class="work__index">{p.num}</span>
            <h3 class="work__title" transition:name={`title-${p.slug}`}>{p.title}</h3>

            <p class="work__meta">
              <span>{p.client} / {p.discipline} / {p.year}</span>
              {p.status && <span class="tag">{p.status}</span>}
            </p>

            <p class="work__summary">{p.summary}</p>

            <span class="work__go">Read the case study<span class="work__arrow" aria-hidden="true">&nbsp;&rarr;</span></span>
          </div>
        </a>
      </li>
    ))}
  </ol>

  {other.length > 0 && (
    <div class="other">
      <h2 class="ghost-head other__label">Other Projects</h2>
      <ul class="other-list">
        {other.map((p) => (
          <li>
            <a class="other__item" href={withBase(`/work/${p.slug}`)}>
              <span class="other__title" transition:name={`title-${p.slug}`}>{p.title}</span>
              <span class="other__meta">{p.client}, {p.year}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
  .selected-work {
    padding-block: var(--section-tight) var(--section);
  }
  .selected-work__label {
    margin-bottom: var(--space-xl);
  }

  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--section);
  }

  /* image | story — the image carries the row. */
  .work {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--space-md) var(--space-2xl);
    align-items: center;
    color: inherit;
  }
  /* Alternate sides on even rows: story left, image right, image keeps 7fr. */
  li:nth-child(even) .work {
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  }
  li:nth-child(even) .work__media { order: 2; }

  .work__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-frame);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-surface);
  }
  .work__media img,
  .work__media-ph {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .work__media-ph {
    display: grid;
    place-items: center;
  }
  .work__media-ph span {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .work:hover .work__media img,
  .work:focus-visible .work__media img,
  .work:hover .work__media-ph,
  .work:focus-visible .work__media-ph {
    transform: scale(1.025);
  }

  .work__index {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-md);
  }

  .work__title {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    max-width: 16ch;
  }

  .work__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .work__summary {
    margin-top: var(--space-md);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-ink-muted);
    max-width: 40ch;
  }

  /* Quiet, permanent affordance; the arrow advances on hover. */
  .work__go {
    display: inline-block;
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    border-bottom: 1px solid var(--color-link-underline);
    padding-bottom: 2px;
    transition: border-color var(--duration) var(--ease-out);
  }
  .work__arrow {
    display: inline-block;
    transition: transform var(--duration) var(--ease-out);
  }
  .work:hover .work__go,
  .work:focus-visible .work__go {
    border-bottom-color: var(--color-link);
  }
  .work:hover .work__arrow,
  .work:focus-visible .work__arrow {
    transform: translateX(4px);
  }


  /* Other projects — the quiet footnote list under the four highlights.
     A coda to the work list, not a peer chapter: tighter above than the
     true section breaks, so one line of content isn't over-announced. */
  .other {
    margin-top: var(--section-tight);
  }
  .other__label {
    margin-bottom: var(--space-lg);
  }
  .other-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 56rem;
  }
  .other__item {
    color: inherit;
    line-height: 1.4;
  }
  .other__title {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: clamp(1.375rem, 1.2rem + 0.6vw, 1.625rem);
    letter-spacing: var(--tracking-tight);
    border-bottom: 1px solid var(--color-hairline-strong);
    padding-bottom: 1px;
    transition: border-color var(--duration) var(--ease-out);
  }
  .other__item:hover .other__title,
  .other__item:focus-visible .other__title {
    border-bottom-color: var(--color-ink);
  }
  .other__meta {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-left: var(--space-sm);
  }

  /* Stack below the point where the split gets cramped: image first, story under.
     The even-row selectors below are as specific as the base ones, so they win
     the cascade and both odd and even rows collapse to a single column. */
  @media (max-width: 56rem) {
    .work,
    li:nth-child(even) .work {
      grid-template-columns: 1fr;
    }
    li:nth-child(even) .work__media { order: 0; }
    .work__index { margin-bottom: var(--space-sm); }
    .work-list { gap: var(--section-tight); }

    /* Other projects: title on its own line, meta beneath it. */
    .other__item { display: block; }
    .other__meta {
      display: block;
      margin-left: 0;
      margin-top: var(--space-2xs);
    }
  }
</style>
