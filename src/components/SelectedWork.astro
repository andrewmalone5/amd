---
// Selected Work — an editorial numbered index, not a card grid. Each row runs
// at the true length of its summary so density varies with the content, not a
// template. Rows are hairline-separated at rest and lift into a surface card on
// hover. The anchor project reads heavier (larger title + status tag).
import { projects } from '../data/projects';
import { withBase } from '../lib/url';
---

<section id="work" class="selected-work column--wide">
  <p class="eyebrow selected-work__label">Selected Work</p>

  <ol class="work-list">
    {projects.map((p) => (
      <li>
        <a class:list={['work', { 'is-anchor': p.anchor }]} href={withBase(`/work/${p.slug}`)}>
          <span class="work__index">{p.num}</span>

          <div class="work__body">
            <div class="work__head">
              <h3 class="work__title">{p.title}</h3>
              <span class="work__arrow" aria-hidden="true">&rarr;</span>
            </div>

            <p class="work__meta">
              <span>{p.client} · {p.discipline} · {p.year}</span>
              {p.status && <span class="tag">{p.status}</span>}
            </p>

            <p class="work__summary">{p.summary}</p>
          </div>
        </a>
      </li>
    ))}
  </ol>
</section>

<style>
  .selected-work {
    padding-block: var(--section-loose);
  }
  .selected-work__label {
    margin-bottom: var(--space-xl);
  }

  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Each entry: number in a left gutter, everything else in the body column. */
  .work {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-lg);
    padding: var(--space-xl) var(--space-md);
    /* 1px border on all sides so hover can draw a full edge with no layout
       shift; only the top shows at rest, acting as the row divider. */
    border: 1px solid transparent;
    border-top-color: var(--color-hairline);
    border-radius: 8px;
    color: inherit;
    transition:
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out),
      background-color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }

  /* Rest = clean divider. Hover = a precisely outlined panel: a crisp hairline
     edge, a tight grounded shadow (a hint of depth, not a soft float), and a
     whisper of lift. Engineered, not a default card. */
  .work:hover,
  .work:focus-visible {
    background: var(--color-surface);
    border-color: var(--color-hairline-strong);
    box-shadow: 0 10px 28px -22px rgba(28, 26, 23, 0.32);
    transform: translateY(-1px);
    outline: none;
  }

  .work__index {
    font-size: var(--text-body);
    color: var(--color-ink-faint);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    padding-top: 0.4em;
    transition: color var(--duration) var(--ease-out);
  }
  /* The number activates on hover — a precise state change. */
  .work:hover .work__index,
  .work:focus-visible .work__index {
    color: var(--color-ink);
  }

  .work__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .work__title {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
  }
  .is-anchor .work__title {
    font-size: var(--text-display-md);
  }

  /* Arrow advances in on hover — the affordance, not a permanent chevron. */
  .work__arrow {
    flex-shrink: 0;
    font-size: 1.35rem;
    color: var(--color-ink-muted);
    opacity: 0;
    transform: translateX(-0.5rem);
    transition:
      opacity var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out);
  }
  .work:hover .work__arrow,
  .work:focus-visible .work__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .work__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .work__summary {
    margin-top: var(--space-md);
    font-size: var(--text-body);
    color: var(--color-ink);
    max-width: 58ch;
  }

  @media (max-width: 33rem) {
    .work {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
      padding-inline: var(--space-xs);
    }
    .work__index { padding-top: 0; }
  }
</style>
