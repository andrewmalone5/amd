---
// Selected Work — image-led alternating rows. The image is the hero: a large
// 4:3 frame taking most of the row, with the story beside it in a narrower
// column, sides alternating per project. Whole row is one link.
import { projects } from '../data/projects';
import { withBase } from '../lib/url';
---

<section id="work" class="selected-work column--wide">
  <p class="eyebrow selected-work__label">Selected Work</p>

  <ol class="work-list">
    {projects.map((p) => (
      <li>
        <a class="work" href={withBase(`/work/${p.slug}`)}>
          <div class="work__media">
            {p.image ? (
              <img src={withBase(p.image)} alt={p.title} loading="lazy" />
            ) : (
              <div class="work__media-ph"><span>Project image</span></div>
            )}
          </div>

          <div class="work__body">
            <span class="work__index">{p.num}</span>
            <h3 class="work__title">{p.title}</h3>

            <p class="work__meta">
              <span>{p.client} / {p.discipline} / {p.year}</span>
              {p.status && <span class="tag">{p.status}</span>}
            </p>

            <p class="work__summary">{p.summary}</p>

            <span class="work__go">Read the case study<span class="work__arrow" aria-hidden="true">&nbsp;&rarr;</span></span>
          </div>
        </a>
      </li>
    ))}
  </ol>
</section>

<style>
  .selected-work {
    padding-block: var(--section-tight) var(--section);
  }
  .selected-work__label {
    margin-bottom: var(--space-2xl);
  }

  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--section);
  }

  /* image | story — the image carries the row. */
  .work {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
    gap: var(--space-md) var(--space-2xl);
    align-items: center;
    color: inherit;
  }
  /* Alternate sides on even rows: story left, image right, image keeps 8fr. */
  li:nth-child(even) .work {
    grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
  }
  li:nth-child(even) .work__media { order: 2; }

  .work__media {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-surface);
  }
  .work__media img,
  .work__media-ph {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .work__media-ph {
    display: grid;
    place-items: center;
  }
  .work__media-ph span {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .work:hover .work__media img,
  .work:focus-visible .work__media img,
  .work:hover .work__media-ph,
  .work:focus-visible .work__media-ph {
    transform: scale(1.025);
  }

  .work__index {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-md);
  }

  .work__title {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    max-width: 16ch;
  }

  .work__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .work__summary {
    margin-top: var(--space-md);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-ink-muted);
    max-width: 40ch;
  }

  /* Quiet, permanent affordance; the arrow advances on hover. */
  .work__go {
    display: inline-block;
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-hairline-strong);
    padding-bottom: 2px;
    transition: border-color var(--duration) var(--ease-out);
  }
  .work__arrow {
    display: inline-block;
    transition: transform var(--duration) var(--ease-out);
  }
  .work:hover .work__go,
  .work:focus-visible .work__go {
    border-bottom-color: var(--color-ink);
  }
  .work:hover .work__arrow,
  .work:focus-visible .work__arrow {
    transform: translateX(4px);
  }
  .work:focus-visible { outline: none; }

  /* Stack below the point where the split gets cramped: image first, story under. */
  @media (max-width: 56rem) {
    .work {
      grid-template-columns: 1fr;
    }
    li:nth-child(even) .work__media { order: 0; }
    .work__index { margin-bottom: var(--space-sm); }
    .work-list { gap: var(--section-tight); }
  }
</style>
