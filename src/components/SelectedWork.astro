---
// Selected Work — an editorial numbered index, not a card grid. Text on the
// left (number, title, meta, summary), a thumbnail on the right. Each row runs
// at the true length of its summary so density still varies with the content.
// Hovering the list spotlights one project and dims the rest. Images fall back
// to a toned placeholder until real ones are set in the data file.
import { projects } from '../data/projects';
import { withBase } from '../lib/url';
---

<section id="work" class="selected-work column--wide">
  <p class="eyebrow selected-work__label">Selected Work</p>

  <ol class="work-list">
    {projects.map((p) => (
      <li>
        <a class:list={['work', { 'is-anchor': p.anchor }]} href={withBase(`/work/${p.slug}`)}>
          <span class="work__index">{p.num}</span>

          <div class="work__body">
            <div class="work__head">
              <h3 class="work__title">{p.title}</h3>
              <span class="work__arrow" aria-hidden="true">&rarr;</span>
            </div>

            <p class="work__meta">
              <span>{p.client} / {p.discipline} / {p.year}</span>
              {p.status && <span class="tag">{p.status}</span>}
            </p>

            <p class="work__summary">{p.summary}</p>
          </div>

          <div class="work__media">
            {p.image ? (
              <img src={withBase(p.image)} alt={p.title} loading="lazy" />
            ) : (
              <div class="work__media-ph"><span>Project image</span></div>
            )}
          </div>
        </a>
      </li>
    ))}
  </ol>
</section>

<style>
  .selected-work {
    padding-block: var(--section-loose);
  }
  .selected-work__label {
    margin-bottom: var(--space-xl);
  }

  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* number | text | thumbnail */
  .work {
    display: grid;
    grid-template-columns: 3rem 1fr minmax(0, 24rem);
    gap: var(--space-lg);
    align-items: start;
    padding: var(--space-xl) var(--space-md);
    border-top: 1px solid var(--color-hairline);
    color: inherit;
    transition: opacity var(--duration) var(--ease-out);
  }

  /* Spotlight: hovering the list dims the other projects; the focused one stays
     lit. No boxes, no shadows — the interaction is light and typographic. */
  .work-list:hover .work { opacity: 0.32; }
  .work-list .work:hover,
  .work-list .work:focus-visible {
    opacity: 1;
    outline: none;
  }

  /* The focused row leans toward its arrow; the number anchors, staying put. */
  .work__body {
    transition: transform var(--duration) var(--ease-out);
  }
  .work:hover .work__body,
  .work:focus-visible .work__body {
    transform: translateX(10px);
  }

  .work__index {
    font-size: var(--text-body);
    color: var(--color-ink-faint);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    padding-top: 0.4em;
    transition: color var(--duration) var(--ease-out);
  }
  .work:hover .work__index,
  .work:focus-visible .work__index {
    color: var(--color-ink);
  }

  .work__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .work__title {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
  }
  .is-anchor .work__title {
    font-size: var(--text-display-md);
  }

  /* Arrow advances in on hover — the affordance, not a permanent chevron. */
  .work__arrow {
    flex-shrink: 0;
    font-size: 1.35rem;
    color: var(--color-ink-muted);
    opacity: 0;
    transform: translateX(-0.5rem);
    transition:
      opacity var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out);
  }
  .work:hover .work__arrow,
  .work:focus-visible .work__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .work__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .work__summary {
    margin-top: var(--space-md);
    font-size: var(--text-body);
    color: var(--color-ink);
    max-width: 52ch;
  }

  /* Thumbnail — consistent size, toned to the palette. Subtle zoom on hover,
     clipped by the frame (the image is always visible, never revealed). */
  .work__media {
    align-self: start;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
  }
  .work__media img,
  .work__media-ph {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .work__media-ph {
    background: var(--color-surface);
    display: grid;
    place-items: center;
  }
  .work__media-ph span {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .work:hover .work__media img,
  .work:hover .work__media-ph,
  .work:focus-visible .work__media img,
  .work:focus-visible .work__media-ph {
    transform: scale(1.03);
  }

  /* Stack below the point where three columns get cramped. */
  @media (max-width: 48rem) {
    .work {
      grid-template-columns: 1fr;
      gap: var(--space-md);
      padding-inline: var(--space-xs);
    }
    .work__index { padding-top: 0; }
    .work__media { max-width: 28rem; }
    .work:hover .work__body,
    .work:focus-visible .work__body { transform: none; }
  }
</style>
