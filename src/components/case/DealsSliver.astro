---
// The deals click-share, drawn live. The two big bars sweep out first; then a
// beat of nothing; then the deal action blinks in at its true size, a 2px
// line. The pause is the argument. Borderless, straight on the paper.
const rows = [
  { label: 'Save, the default action', value: '60%', w: 60 },
  { label: 'Win BackBox, the generic pricing action', value: '40%', w: 40 },
];
---

<div class="block block--sliver" data-sliver>
  {rows.map((r, i) => (
    <div class="row" style={`--w: ${r.w}%; --d: ${(i * 0.3).toFixed(1)}s`}>
      <p class="row__label">{r.label}</p>
      <div class="row__track">
        <div class="row__bar"></div>
        <span class="row__val">{r.value}</span>
      </div>
    </div>
  ))}

  <div class="row row--deal">
    <p class="row__label">The deal action, the one this page exists to drive</p>
    <div class="row__track">
      <div class="row__bar row__bar--sliver"></div>
      <span class="row__val">0.2%</span>
    </div>
  </div>

  <p class="note">
    Meanwhile: <strong>10 deal CSVs a day</strong>, walked through with a human.
    The workaround was the real interface.
  </p>
</div>

<style>
  .block--sliver {
    margin: 0;
  }

  .row + .row { margin-top: var(--space-lg); }

  .row__label {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-xs);
  }
  .row--deal .row__label {
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
  }

  .row__track {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* The two big bars: outlined boxes that sweep out to their share. */
  .row__bar {
    width: 0;
    height: 2.5rem;
    border: 1.5px solid var(--color-ink);
    background: var(--color-paper);
  }
  [data-sliver].is-in .row__bar {
    width: var(--w);
    transition: width 0.9s var(--ease-out);
    transition-delay: var(--d);
  }

  /* The deal action at its true size. It arrives late, after the pause. */
  .row__bar--sliver {
    width: 2px;
    border: 0;
    background: var(--color-ink);
    opacity: 0;
  }
  [data-sliver].is-in .row__bar--sliver {
    opacity: 1;
    transition: opacity var(--duration) var(--ease-out) 1.5s;
  }

  .row__val {
    font-size: 1.0625rem;
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
    opacity: 0;
  }
  [data-sliver].is-in .row__val {
    opacity: 1;
    transition: opacity var(--duration-slow) var(--ease-out);
    transition-delay: calc(var(--d, 1.5s) + 0.6s);
  }

  .note {
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    opacity: 0;
    transform: translateY(0.5rem);
  }
  .note strong { color: var(--color-ink); }
  [data-sliver].is-in .note {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-slow) var(--ease-out) 2s,
      transform var(--duration-slow) var(--ease-out) 2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .row__bar { width: var(--w); }
    .row__bar--sliver { width: 2px; opacity: 1; }
    .row__val, .note { opacity: 1; transform: none; }
    [data-sliver].is-in .row__bar,
    [data-sliver].is-in .row__bar--sliver,
    [data-sliver].is-in .row__val,
    [data-sliver].is-in .note { transition: none; }
  }
</style>

<script>
  // Runs per page visit: view-transition navigations rebuild the DOM
  // without re-executing module scripts, so astro:page-load re-inits.
  const init = () => {
    const el = document.querySelector<HTMLElement>('[data-sliver]');
    if (el && !el.dataset.bound) {
      el.dataset.bound = '1';
      new IntersectionObserver(
        (entries, io) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              el.classList.add('is-in');
              io.disconnect();
            }
          }
        },
        { threshold: 0.4 }
      ).observe(el);
    }
  };
  init();
  document.addEventListener('astro:page-load', init);
</script>
