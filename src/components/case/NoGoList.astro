---
// The no-go list, shown as the product's own pattern: two automations were
// proposed for the roadmap, and each got the accept-or-reject treatment the
// posture demands — decided by the seller evidence, not by appetite.
const cards = [
  {
    proposed: 'Automated pricing decisions',
    instead: 'Price suggestions with an explicit accept step.',
  },
  {
    proposed: 'Autonomous listing changes',
    instead: 'Proposed edits the seller confirms, one by one.',
  },
];
---

<section class="block block--nogo">
  <p class="eyebrow nogo__kicker">The no-go list</p>
  <p class="nogo__rule">AI proposes, the seller approves. Nothing reprices or edits a listing on its own.</p>

  <div class="nogo__cards">
    {cards.map((c) => (
      <article class="nogo__card">
        <p class="nogo__tag">Proposed automation</p>
        <h3 class="nogo__title">{c.proposed}</h3>
        <p class="nogo__verdict">
          <svg viewBox="0 0 12 12" aria-hidden="true"><path d="M2 2 L10 10 M10 2 L2 10" /></svg>
          Rejected, on the evidence
        </p>
        <p class="nogo__instead"><strong>Shipped instead&nbsp;&nbsp;</strong>{c.instead}</p>
      </article>
    ))}
  </div>

  <p class="nogo__coda">The roadmap went through the product&rsquo;s own posture: proposed, and the seller evidence decided.</p>
</section>

<style>
  /* The one purple word mid-page: the kicker above the study's hard rule. */
  .nogo__kicker {
    margin-bottom: var(--space-sm);
    color: var(--color-mark);
  }
  .nogo__rule {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
    text-wrap: balance;
    max-width: 40ch;
  }

  .nogo__cards {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  .nogo__card {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-frame);
    padding: var(--space-lg) var(--space-xl);
    background: var(--color-surface);
  }
  .nogo__tag {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .nogo__title {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
  }
  .nogo__verdict {
    margin-top: var(--space-sm);
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-mark);
  }
  .nogo__verdict svg {
    width: 0.65em;
    height: 0.65em;
    flex: none;
  }
  .nogo__verdict svg path {
    stroke: var(--color-mark);
    stroke-width: 2.4;
    stroke-linecap: round;
  }
  .nogo__instead {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .nogo__instead strong {
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
  }

  .nogo__coda {
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  @media (max-width: 48rem) {
    .nogo__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
