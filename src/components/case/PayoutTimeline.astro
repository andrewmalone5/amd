---
// The seven-day wait, drawn at true length. The standard payout line crawls
// across the whole week, tick by tick; then BackFunds lands the same money on
// day one. The drawing time is the argument, and D+1 gets its meaning from
// the dot it labels instead of floating as jargon.
const days = [1, 2, 3, 4, 5, 6];
const pos = (d: number) => 1 + d * 14; // sale at 1%, day seven at 99%
---

<div class="block block--payout" data-payout>
  <div class="pt pt--standard">
    <p class="pt__kicker">Standard payout</p>
    <p class="pt__drift">a week of working capital, locked up</p>
    <div class="pt__lane">
      <span class="pt__line pt__line--slow"></span>
      <span class="pt__dot pt__dot--sale"></span>
      {days.map((d) => (
        <span class="pt__tick" style={`--pos: ${pos(d)}%; --d: ${(d * 0.33).toFixed(2)}s`}></span>
      ))}
      <span class="pt__dot pt__dot--paid-standard"></span>
    </div>
    <div class="pt__ends"><span>sale</span><span>paid about seven days later</span></div>
  </div>

  <div class="pt pt--fast">
    <p class="pt__kicker">With BackFunds</p>
    <div class="pt__lane">
      <span class="pt__week"></span>
      <span class="pt__line pt__line--fast"></span>
      <span class="pt__dot pt__dot--sale pt__dot--sale-fast"></span>
      <span class="pt__dot pt__dot--paid-fast"></span>
      <span class="pt__dlabel"><strong>D+1</strong>&ensp;paid the next business day</span>
    </div>
    <div class="pt__ends"><span>sale</span><span class="pt__scale">day seven, for scale</span></div>
  </div>
</div>

<style>
  .block--payout {
    margin: 0;
  }

  .pt + .pt { margin-top: var(--space-2xl); }

  .pt__kicker {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-md);
  }
  .pt--fast .pt__kicker { margin-bottom: var(--space-lg); }

  /* The standard row's only commentary: the wait, written across it. */
  .pt__drift {
    text-align: center;
    margin-bottom: var(--space-2xs);
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    opacity: 0;
  }
  [data-payout].is-in .pt__drift {
    opacity: 1;
    transition: opacity var(--duration-slow) var(--ease-out) 1s;
  }

  .pt__lane {
    position: relative;
    height: 1.5rem;
  }
  /* The BackFunds lane carries the D+1 label above the line. */
  .pt--fast .pt__lane { height: 3.25rem; }

  /* The week, crawled across: near-linear on purpose, so it takes its time. */
  .pt__line {
    position: absolute;
    top: 50%;
    left: 1%;
    height: 1.5px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left;
  }
  .pt__line--slow { width: 98%; }
  [data-payout].is-in .pt__line--slow {
    transform: scaleX(1);
    transition: transform 2.4s cubic-bezier(0.45, 0, 0.55, 1);
  }

  /* Day ticks appear as the line passes them. */
  .pt__tick {
    position: absolute;
    top: 50%;
    left: var(--pos);
    width: 1.5px;
    height: 0.6rem;
    background: var(--color-hairline-strong);
    transform: translate(-50%, -50%);
    opacity: 0;
  }
  [data-payout].is-in .pt__tick {
    opacity: 1;
    transition: opacity var(--duration) var(--ease-out);
    transition-delay: var(--d);
  }

  .pt__dot {
    position: absolute;
    top: 50%;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-ink);
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
  }
  .pt__dot--sale { left: 1%; }
  .pt__dot--paid-standard { left: 99%; }
  .pt__dot--paid-fast { left: 15%; }
  [data-payout].is-in .pt__dot {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    transition:
      opacity var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out);
  }
  [data-payout].is-in .pt__dot--paid-standard { transition-delay: 2.4s; }
  [data-payout].is-in .pt__dot--sale-fast { transition-delay: 2.6s; }
  [data-payout].is-in .pt__dot--paid-fast { transition-delay: 3.1s; }

  /* The same week, drawn faint for scale under the fast lane. */
  .pt__week {
    position: absolute;
    top: 50%;
    left: 1%;
    width: 98%;
    height: 1.5px;
    background: var(--color-hairline);
    opacity: 0;
  }
  [data-payout].is-in .pt__week {
    opacity: 1;
    transition: opacity var(--duration-slow) var(--ease-out) 2.6s;
  }

  /* The payout, landing on day one: one short quick stroke after the crawl. */
  .pt__line--fast { width: 14%; }
  [data-payout].is-in .pt__line--fast {
    transform: scaleX(1);
    transition: transform 0.4s var(--ease-out) 2.8s;
  }

  /* D+1, finally in context: the label on the dot where the money lands. */
  .pt__dlabel {
    position: absolute;
    left: 15%;
    bottom: calc(50% + 0.7rem);
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    opacity: 0;
  }
  .pt__dlabel strong {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
  }
  [data-payout].is-in .pt__dlabel {
    opacity: 1;
    transition: opacity var(--duration-slow) var(--ease-out) 3.3s;
  }

  .pt__ends {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-ink);
  }
  .pt__scale { color: var(--color-ink-muted); }

  /* Mobile: the centred label would clip past the lane's left edge, so it
     anchors to the lane start instead, and the drift reads as a lead-in. */
  @media (max-width: 44rem) {
    .pt__drift { text-align: left; margin-bottom: var(--space-sm); }
    .pt__dlabel { left: 1%; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pt__line { transform: scaleX(1); }
    .pt__dot { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    .pt__drift, .pt__tick, .pt__week, .pt__dlabel { opacity: 1; }
    [data-payout].is-in .pt__line,
    [data-payout].is-in .pt__dot,
    [data-payout].is-in .pt__drift,
    [data-payout].is-in .pt__tick,
    [data-payout].is-in .pt__week,
    [data-payout].is-in .pt__dlabel { transition: none; }
  }
</style>

<script>
  const el = document.querySelector<HTMLElement>('[data-payout]');
  if (el) {
    new IntersectionObserver(
      (entries, io) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            el.classList.add('is-in');
            io.disconnect();
          }
        }
      },
      { threshold: 0.4 }
    ).observe(el);
  }
</script>
