---
// The narrative-first story arc, drawn live instead of shipped as a PNG.
// Replaces both the seven-questions pairs list and the static artwork: the
// curve draws itself when it enters the viewport, the plot points land in
// sequence, and hovering a question places it on the curve. Sits directly on
// the paper — no frame, no border.
const plots = [
  { n: '01', q: 'What does the user want?', a: 'Their goal in their words, not the feature’s description of it.' },
  { n: '02', q: 'Why can’t they get it today?', a: 'The obstacle that makes the current path fail, cost too much, or feel too risky.' },
  { n: '03', q: 'What do we introduce?', a: 'The feature, told as an event in the user’s story rather than a spec.' },
  { n: '04', q: 'What would stop them adopting it?', a: 'The hesitation. The plot point teams skip.', crisis: true },
  { n: '05', q: 'What convinces them to cross?', a: 'The proof or the moment that makes trying it feel safe and worth it.' },
  { n: '06', q: 'What changes in their behaviour?', a: 'What they now do differently, and what that demands of the product around it.' },
  { n: '07', q: 'What does success look like?', a: 'The observable outcome for the user, and the measurable one for the team.' },
];

// Node positions along the curve; plot four dips — the crisis.
const nodes = [
  { x: 105, y: 118 }, { x: 315, y: 84 }, { x: 525, y: 58 },
  { x: 735, y: 122 }, { x: 945, y: 74 }, { x: 1155, y: 34 }, { x: 1365, y: 16 },
];
---

<figure class="block block--arc" data-arc>
  <svg viewBox="0 0 1472 196" role="img" aria-label="The seven plot points on a story curve. It rises through the setup, dips at plot point four, the crisis, and resolves upward.">
    <line class="arc__baseline" x1="0" y1="150" x2="1472" y2="150" />
    <path
      class="arc__line"
      pathLength="1"
      d="M105 118 C 230 96, 300 88, 315 84 S 480 62, 525 58 S 690 100, 735 122 S 900 96, 945 74 S 1120 40, 1155 34 S 1330 20, 1365 16"
    />
    {nodes.map((p, i) => (
      <g class:list={['arc__node', { 'arc__node--crisis': plots[i].crisis }]} data-node={i} style={`--d: ${(0.12 + i * 0.21).toFixed(2)}s`}>
        <circle cx={p.x} cy={p.y} r={plots[i].crisis ? 14 : 12} />
        <text x={p.x} y={p.y + 4}>{i + 1}</text>
      </g>
    ))}
    <text class="arc__crisis-label" x="735" y="176">the crisis: will they change?</text>
  </svg>

  <ol class="arc__plots">
    {plots.map((p, i) => (
      <li class:list={['plot', { 'plot--crisis': p.crisis }]} data-node={i} style={`--d: ${(0.35 + i * 0.09).toFixed(2)}s`}>
        <span class="plot__n">{p.n}</span>
        <h3 class="plot__q">{p.q}</h3>
        <p class="plot__a">{p.a}</p>
      </li>
    ))}
  </ol>
</figure>

<style>
  .block--arc {
    margin: 0;
  }

  svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .arc__baseline {
    stroke: var(--color-hairline);
    stroke-width: 1;
  }

  /* The curve draws itself left to right once the block is in view. */
  .arc__line {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
  [data-arc].is-in .arc__line {
    transition: stroke-dashoffset 1.7s var(--ease-out);
    stroke-dashoffset: 0;
  }

  /* Nodes land in sequence as the line reaches them. */
  .arc__node {
    opacity: 0;
  }
  .arc__node circle {
    fill: var(--color-paper);
    stroke: var(--color-ink);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.4);
    transition:
      transform var(--duration) var(--ease-out),
      fill var(--duration-fast) var(--ease-out);
  }
  .arc__node text {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    fill: var(--color-ink);
    text-anchor: middle;
    transition: fill var(--duration-fast) var(--ease-out);
  }
  .arc__node--crisis circle { fill: var(--color-ink); }
  .arc__node--crisis text { fill: var(--color-paper); }
  [data-arc].is-in .arc__node {
    opacity: 1;
    transition: opacity var(--duration) var(--ease-out);
    transition-delay: var(--d);
  }
  [data-arc].is-in .arc__node circle {
    transform: scale(1);
    transition-delay: var(--d);
  }

  .arc__crisis-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    fill: var(--color-ink-muted);
    text-anchor: middle;
    opacity: 0;
  }
  [data-arc].is-in .arc__crisis-label {
    opacity: 1;
    transition: opacity var(--duration-slow) var(--ease-out) 0.9s;
  }

  /* Hovering a question lights its node; the rest of the arc steps back.
     Driven by JS classes, not :hover chains, so moving between questions
     hands the highlight over instead of flashing everything back. */
  .arc__node.is-hot circle {
    fill: var(--color-ink);
    transform: scale(1.3);
  }
  .arc__node.is-hot text { fill: var(--color-paper); }
  [data-arc].has-focus .arc__node:not(.is-hot) { opacity: 0.35; }
  [data-arc].has-focus .arc__crisis-label { opacity: 0.35; }
  [data-arc].has-focus .arc__node--crisis.is-hot ~ .arc__crisis-label { opacity: 1; }
  [data-arc].has-focus .plot:not(.is-hot) { opacity: 0.45; }

  /* The questions, beneath their plot points. */
  .arc__plots {
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-sm);
  }
  .plot {
    position: relative;
    padding-top: var(--space-xs);
    opacity: 0;
    transform: translateY(0.75rem);
  }
  /* Each question opens with its own rule, drawn in on arrival. */
  .plot::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-hairline-strong);
    transform: scaleX(0);
    transform-origin: left;
  }
  .plot--crisis::before {
    height: 2px;
    background: var(--color-ink);
  }
  [data-arc].is-in .plot {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-slow) var(--ease-out),
      transform var(--duration-slow) var(--ease-out);
    transition-delay: var(--d);
  }
  [data-arc].is-in .plot::before {
    transform: scaleX(1);
    transition: transform var(--duration-slow) var(--ease-out);
    transition-delay: var(--d);
  }

  .plot__n {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-label);
    color: var(--color-ink-faint);
  }
  .plot--crisis .plot__n { color: var(--color-ink); }
  .plot__q {
    margin-top: var(--space-3xs);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    line-height: 1.35;
    color: var(--color-ink);
  }
  .plot--crisis .plot__q {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: 1.0625rem;
  }
  .plot__a {
    margin-top: var(--space-3xs);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* Once the entrance has played, the stagger delays come off and everything
     responds at hover speed. Without this, every dim and highlight replays
     the entrance choreography — the far nodes lag by over a second. */
  [data-arc].is-settled .arc__node,
  [data-arc].is-settled .arc__node circle,
  [data-arc].is-settled .arc__crisis-label,
  [data-arc].is-settled .plot {
    transition-delay: 0s;
    transition-duration: var(--duration-fast);
  }

  @media (max-width: 64rem) {
    .arc__plots { grid-template-columns: 1fr 1fr; gap: var(--space-md) var(--space-lg); }
  }
  @media (max-width: 40rem) {
    .arc__plots { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .arc__line { stroke-dashoffset: 0; }
    .arc__node, .arc__crisis-label, .plot { opacity: 1; transform: none; }
    .arc__node circle { transform: scale(1); }
    .plot::before { transform: scaleX(1); }
    [data-arc].is-in .arc__line,
    [data-arc].is-in .arc__node,
    [data-arc].is-in .arc__node circle,
    [data-arc].is-in .arc__crisis-label,
    [data-arc].is-in .plot,
    [data-arc].is-in .plot::before { transition: none; }
  }
</style>

<script>
  const arc = document.querySelector<HTMLElement>('[data-arc]');
  if (arc) {
    // Draw the arc once it's properly in view; ~1.8s later the entrance is
    // done and .is-settled switches every transition to hover speed.
    new IntersectionObserver(
      (entries, io) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            arc.classList.add('is-in');
            setTimeout(() => arc.classList.add('is-settled'), 1800);
            io.disconnect();
          }
        }
      },
      { threshold: 0.35 }
    ).observe(arc);

    // One focus at a time: entering a question (or a plot point on the curve)
    // hands the highlight over; it only clears on leaving the group entirely.
    const focus = (i: string | undefined) => {
      arc.querySelectorAll('.is-hot').forEach((el) => el.classList.remove('is-hot'));
      if (i === undefined) {
        arc.classList.remove('has-focus');
        return;
      }
      arc.querySelectorAll(`[data-node="${i}"]`).forEach((el) => el.classList.add('is-hot'));
      arc.classList.add('has-focus');
    };

    arc.querySelectorAll<HTMLElement>('.plot, .arc__node').forEach((el) => {
      el.addEventListener('mouseenter', () => focus(el.dataset.node));
    });
    arc.querySelectorAll('.arc__plots, svg').forEach((group) => {
      group.addEventListener('mouseleave', () => focus(undefined));
    });
  }
</script>
