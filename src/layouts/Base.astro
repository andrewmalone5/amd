---
// Minimal HTML shell: self-hosted fonts + global styles + the head metadata
// every page shares — description, canonical, social card.
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  /** Per-page meta description; pages pass their own summary. */
  description?: string;
  /** Owner-only pages (the shot list) opt out of search indexing. */
  noindex?: boolean;
}
const {
  title = 'Portfolio',
  description = 'Andrew Malone is a senior product designer in Berlin who designs the systems behind the interface — case studies in embedded finance, AI strategy, and seller tools.',
  noindex = false,
} = Astro.props;

// Absolute URLs for canonical + social cards; Astro.site carries the domain.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(withBase('/og.png'), Astro.site).href;

// Self-hosted so the typefaces never fall back to a system font, load without a
// third-party request, and survive a network the CDN can't reach. Referenced
// with the site base so a domain/base change carries them along.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fontFaces = `
  @font-face {
    font-family: 'Spectral';
    font-style: normal; font-weight: 400; font-display: swap;
    src: url('${base}/fonts/spectral-400.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Spectral';
    font-style: italic; font-weight: 400; font-display: swap;
    src: url('${base}/fonts/spectral-400-italic.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Spectral';
    font-style: normal; font-weight: 600; font-display: swap;
    src: url('${base}/fonts/spectral-600.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Hanken Grotesk';
    font-style: normal; font-weight: 400 600; font-display: swap;
    src: url('${base}/fonts/hanken-grotesk-var.woff2') format('woff2-variations');
  }
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Shot-list mode (owner tool): ?shotlist turns it on for the session,
        ?shotlist=0 turns it off. Visitors never see it. */}
    <script is:inline>
      try {
        var q = new URLSearchParams(location.search);
        if (q.has('shotlist')) {
          if (q.get('shotlist') === '0') sessionStorage.removeItem('amd-shotlist');
          else sessionStorage.setItem('amd-shotlist', '1');
        }
        if (sessionStorage.getItem('amd-shotlist')) document.documentElement.dataset.shotlist = '1';
      } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <link rel="icon" href={`${base}/favicon.png`} type="image/png" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Andrew Malone" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preload" href={`${base}/fonts/hanken-grotesk-var.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/spectral-400.woff2`} as="font" type="font/woff2" crossorigin />
    {/* The italic carries half the hero statement — as render-critical as the roman. */}
    <link rel="preload" href={`${base}/fonts/spectral-400-italic.woff2`} as="font" type="font/woff2" crossorigin />
    <style set:html={fontFaces}></style>

    {/* View transitions: project titles morph from list row to case headline.
        Falls back to instant navigation under prefers-reduced-motion and in
        browsers without the View Transitions API. */}
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
