---
// Minimal HTML shell: fonts + global styles. Nav/footer come later, once the
// foundations are approved.
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600&family=Spectral:ital,wght@0,400;1,400&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
