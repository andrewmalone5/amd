---
// The page shell: header + main + footer. Every real page composes this.
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  /** Case-study pages pass true: footer keeps only the meta line, no contact CTA. */
  minimalFooter?: boolean;
}
const { title, minimalFooter = false } = Astro.props;
---

<Base title={title}>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer minimal={minimalFooter} />
</Base>
