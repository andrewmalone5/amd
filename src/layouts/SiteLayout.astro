---
// The page shell: header + main + footer. Every real page composes this.
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<Base title={title}>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</Base>
