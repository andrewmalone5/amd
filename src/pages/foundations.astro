---
import Base from '../layouts/Base.astro';

const typeScale = [
  { token: '--text-display-xl', label: 'Display XL', use: 'hero / name', px: '56 → 128', font: 'display' },
  { token: '--text-display-lg', label: 'Display LG', use: 'page headline (h1)', px: '44 → 88', font: 'display' },
  { token: '--text-display-md', label: 'Display MD', use: 'section head (h2)', px: '32 → 52', font: 'display' },
  { token: '--text-display-sm', label: 'Display SM', use: 'sub-head (h3)', px: '24 → 32', font: 'display' },
  { token: '--text-lead', label: 'Lead', use: 'intro / pull-lead', px: '20 → 24', font: 'body' },
  { token: '--text-body', label: 'Body', use: 'body copy', px: '18', font: 'body' },
  { token: '--text-sm', label: 'Small', use: 'meta / captions', px: '15', font: 'body' },
  { token: '--text-xs', label: 'Eyebrow', use: 'labels', px: '13', font: 'body' },
];

const colors = [
  { token: '--color-paper', hex: '#F6F4EE', name: 'Paper', use: 'base' },
  { token: '--color-surface', hex: '#FBFAF6', name: 'Surface', use: 'raised card' },
  { token: '--color-ink', hex: '#1C1A17', name: 'Ink', use: 'primary text' },
  { token: '--color-ink-muted', hex: '#6A655D', name: 'Ink muted', use: 'secondary' },
  { token: '--color-ink-faint', hex: '#9C968C', name: 'Ink faint', use: 'tertiary' },
  { token: '--color-hairline', hex: '#E4E0D6', name: 'Hairline', use: 'thin rules' },
  { token: '--color-hairline-strong', hex: '#CFC9BC', name: 'Hairline strong', use: 'divider' },
];

const spacing = [
  { token: '--space-2xs', px: 8 }, { token: '--space-xs', px: 12 },
  { token: '--space-sm', px: 16 }, { token: '--space-md', px: 24 },
  { token: '--space-lg', px: 40 }, { token: '--space-xl', px: 64 },
  { token: '--space-2xl', px: 96 }, { token: '--space-3xl', px: 144 },
  { token: '--space-4xl', px: 208 },
];
---

<Base title="Foundations">
  <main class="column column--wide">

    <header class="head">
      <p class="eyebrow">Design foundations</p>
      <h1 class="head__title">The visual language, before the pages.</h1>
      <p class="head__note">Type scale, color, spacing. Judge the drama and the range here — everything downstream inherits it.</p>
    </header>

    <!-- TYPE SCALE ------------------------------------------------------- -->
    <section class="block">
      <p class="eyebrow section-label">Type scale</p>
      <div class="scale">
        {typeScale.map((t) => (
          <div class="scale__row">
            <div class="scale__meta">
              <span class="scale__name">{t.label}</span>
              <span class="scale__px">{t.px}px</span>
            </div>
            <div
              class="scale__specimen"
              style={`font-size: var(${t.token}); font-family: var(--font-${t.font}); line-height: 1.05; ${t.font === 'display' ? 'letter-spacing: var(--tracking-display);' : ''}`}
            >
              Trust is a design material
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CONTRAST DEMO ---------------------------------------------------- -->
    <section class="block">
      <p class="eyebrow section-label">Headline against body</p>
      <div class="demo">
        <h2 class="demo__head">When "instant" isn't</h2>
        <p class="demo__body">
          Instant transfers aren't instant when they fail. I designed the waiting and
          failure states nobody wants to think about. The distance you see between this
          serif and the sans below it is the point — the headline should feel like a
          different register entirely, not a bigger version of the same voice.
        </p>
      </div>
    </section>

    <!-- COLOR ------------------------------------------------------------ -->
    <section class="block">
      <p class="eyebrow section-label">Color</p>
      <div class="swatches">
        {colors.map((c) => (
          <div class="swatch">
            <div class="swatch__chip" style={`background: ${c.hex};`}></div>
            <div class="swatch__meta">
              <span class="swatch__name">{c.name}</span>
              <span class="swatch__hex">{c.hex}</span>
              <span class="swatch__use">{c.use}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SPACING ---------------------------------------------------------- -->
    <section class="block">
      <p class="eyebrow section-label">Spacing — a range, not a default</p>
      <div class="spacing">
        {spacing.map((s) => (
          <div class="spacing__row">
            <span class="spacing__label">{s.token.replace('--space-', '')} · {s.px}</span>
            <span class="spacing__bar" style={`width: var(${s.token});`}></span>
          </div>
        ))}
      </div>
    </section>

    <!-- HAIRLINE SYSTEM -------------------------------------------------- -->
    <section class="block block--last">
      <p class="eyebrow section-label">Hairline &amp; lift</p>
      <div class="cards">
        <article class="card">
          <p class="eyebrow">01</p>
          <h3 class="card__title">A dashboard people opened on purpose</h3>
          <p class="card__meta">Neobank · Merchant Tools · 2022–23</p>
        </article>
        <article class="card">
          <p class="eyebrow">02</p>
          <h3 class="card__title">Onboarding without the drop-off</h3>
          <p class="card__meta">Fintech startup · Mobile · 2021</p>
        </article>
      </div>
      <p class="hint">Hover a card — that lift and settle is the signature motion.</p>
    </section>

  </main>
</Base>

<style>
  .head {
    padding-block: var(--space-3xl) var(--space-2xl);
    border-bottom: 1px solid var(--color-hairline);
  }
  .head__title {
    font-size: var(--text-display-lg);
    max-width: 16ch;
    margin-block: var(--space-md) var(--space-lg);
  }
  .head__note {
    font-size: var(--text-lead);
    color: var(--color-ink-muted);
    max-width: 46ch;
  }

  /* Deliberately uneven block spacing — not one rhythm applied to all. */
  .block { padding-block: var(--space-2xl); border-bottom: 1px solid var(--color-hairline); }
  .block--last { border-bottom: 0; padding-bottom: var(--space-3xl); }

  .section-label { margin-bottom: var(--space-xl); }

  /* Type scale rows */
  .scale__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs);
    padding-block: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
  }
  .scale__row:first-child { border-top: 0; }
  .scale__meta {
    display: flex;
    gap: var(--space-md);
    align-items: baseline;
  }
  .scale__name {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .scale__px { font-size: var(--text-sm); color: var(--color-ink-faint); }
  .scale__specimen { color: var(--color-ink); }

  /* Contrast demo */
  .demo__head {
    font-size: var(--text-display-md);
    margin-bottom: var(--space-md);
  }
  .demo__body {
    font-size: var(--text-body);
    color: var(--color-ink);
    max-width: var(--measure);
  }

  /* Color swatches */
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-md);
  }
  .swatch__chip {
    height: 120px;
    border-radius: 4px;
    border: 1px solid var(--color-hairline-strong);
    margin-bottom: var(--space-sm);
  }
  .swatch__meta { display: flex; flex-direction: column; gap: 2px; }
  .swatch__name { font-weight: var(--weight-medium); font-size: var(--text-sm); }
  .swatch__hex { font-size: var(--text-sm); color: var(--color-ink-muted); font-variant-numeric: tabular-nums; }
  .swatch__use { font-size: var(--text-xs); color: var(--color-ink-faint); }

  /* Spacing bars */
  .spacing { display: flex; flex-direction: column; gap: var(--space-sm); }
  .spacing__row { display: flex; align-items: center; gap: var(--space-md); }
  .spacing__label {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    width: 88px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .spacing__bar {
    height: 14px;
    background: var(--color-ink);
    border-radius: 2px;
  }

  /* Cards — hairline + lift */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
  }
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    transform: translateY(0);
    transition:
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lift);
    border-color: var(--color-hairline-strong);
  }
  .card__title { margin-block: var(--space-sm) var(--space-md); }
  .card__meta { font-size: var(--text-sm); color: var(--color-ink-muted); }

  .hint { font-size: var(--text-sm); color: var(--color-ink-faint); margin-top: var(--space-lg); }
</style>
