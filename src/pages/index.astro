---
import SiteLayout from '../layouts/SiteLayout.astro';
import SelectedWork from '../components/SelectedWork.astro';
import HowIWork from '../components/HowIWork.astro';
import About from '../components/About.astro';
---

<SiteLayout title="Andrew Malone, Senior Product Designer">
  <!-- HERO — the statement runs the full measure, largest type on the site.
       Beneath it, an offset row: meta anchoring bottom-left, intro on the right. -->
  <section class="hero column--wide" id="intro">
    <h1 class="hero__statement">Designing systems that turn <em>complexity into clarity.</em></h1>
    <div class="hero__row">
      <div class="hero__meta">
        <p class="hero__current">Currently <strong>Senior Product Designer</strong> at <a href="https://www.backmarket.com" target="_blank" rel="noopener">Back Market</a></p>
        <p class="hero__location">Berlin, Germany</p>
      </div>
      <p class="hero__intro">I&rsquo;m a product designer drawn to how complex systems work, and to making them understandable to the people who depend on them. I work best on hard problems, across teams, where design shapes more than the interface.</p>
    </div>
  </section>

  <SelectedWork />

  <HowIWork />

  <About />
</SiteLayout>

<style>
  /* HERO ---------------------------------------------------------------- */
  .hero {
    padding-block: var(--space-2xl) var(--section);
  }
  /* The statement takes the full measure and balances to about three lines.
     19ch is tuned to this exact sentence — retune if the copy changes. */
  .hero__statement {
    font-size: clamp(2.75rem, 1.5rem + 4.8vw, 6rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    max-width: 19ch;
  }
  /* The payoff phrase, set in italic and eased back a tone — the one two-tone
     moment, echoing the existing site. */
  .hero__statement em {
    font-style: italic;
    color: var(--color-ink-muted);
  }

  /* The supporting row: role meta anchors bottom-left, the intro sits in a
     right-hand column, its last line level with the meta. */
  .hero__row {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: 1fr minmax(0, 36rem);
    gap: var(--space-lg) var(--space-2xl);
    align-items: end;
  }
  .hero__intro {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
    max-width: 44ch;
  }

  @media (max-width: 56rem) {
    .hero__row {
      grid-template-columns: 1fr;
      align-items: start;
    }
    /* Stacked: intro reads first, meta closes. */
    .hero__meta { order: 2; }
    .hero__intro { order: 1; }
  }

  /* Currently / location metadata. */
  .hero__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .hero__current,
  .hero__location {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .hero__current strong {
    color: var(--color-ink);
    font-weight: var(--weight-medium);
  }
  .hero__current a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-hairline-strong);
    transition: border-color var(--duration) var(--ease-out);
  }
  .hero__current a:hover { border-bottom-color: var(--color-ink); }

  /* Reveal — slow, staggered, eased. Resting state is visible; the keyframe
     runs from hidden, with fill-mode backwards so there's no flash. Under
     prefers-reduced-motion the global reset collapses it to an instant show. */
  .hero__statement,
  .hero__intro,
  .hero__meta {
    animation: hero-rise var(--duration-slow) var(--ease-out) backwards;
  }
  .hero__statement { animation-delay: 40ms; }
  .hero__intro { animation-delay: 180ms; }
  .hero__meta { animation-delay: 320ms; }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(0.9rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
