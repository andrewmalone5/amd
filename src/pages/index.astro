---
import SiteLayout from '../layouts/SiteLayout.astro';
import SelectedWork from '../components/SelectedWork.astro';
import HowIWork from '../components/HowIWork.astro';
import About from '../components/About.astro';
---

<SiteLayout title="Andrew Malone — Senior Product Designer">
  <!-- HERO — leads with the positioning statement. Display XL, used here and
       nowhere else on the site. Copy is Andrew's, from the existing site. -->
  <section class="hero column--wide" id="intro">
    <h1 class="hero__statement">Designing systems that turn <em>complexity into clarity.</em></h1>
    <p class="hero__intro">I&rsquo;m a product designer who gets genuinely interested in how complex systems work, and even more interested in making them understandable to the people who depend on them. I work best on hard problems, across teams, where design shapes more than just the interface.</p>
    <div class="hero__meta">
      <p class="hero__current">Currently <strong>Senior Product Designer</strong> at <a href="https://www.backmarket.com" target="_blank" rel="noopener">Back Market</a></p>
      <p class="hero__location">Berlin, Germany</p>
    </div>
  </section>

  <SelectedWork />

  <HowIWork />

  <About />
</SiteLayout>

<style>
  /* HERO ---------------------------------------------------------------- */
  .hero {
    padding-block: var(--space-lg) var(--section-loose);
  }
  .hero__statement {
    /* Sized to keep the whole hero — headline, intro, and role — in the first
       screen. Smaller than the Display XL ceiling, which was too big for this
       longer line. */
    font-size: clamp(2.25rem, 1.3rem + 3.2vw, 4.25rem);
    line-height: 1.06;
    letter-spacing: var(--tracking-display);
    max-width: 18ch;
    margin-bottom: var(--space-lg);
  }
  /* The payoff phrase, set in italic and eased back a tone — the one two-tone
     moment, echoing the existing site. */
  .hero__statement em {
    font-style: italic;
    color: var(--color-ink-muted);
  }
  .hero__intro {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
    max-width: 40ch; /* narrower than the headline — the asymmetry is the design */
  }

  /* Currently / location metadata, below the intro. */
  .hero__meta {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .hero__current,
  .hero__location {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .hero__current strong {
    color: var(--color-ink);
    font-weight: var(--weight-medium);
  }
  .hero__current a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-hairline-strong);
    transition: border-color var(--duration) var(--ease-out);
  }
  .hero__current a:hover { border-bottom-color: var(--color-ink); }

  /* Reveal — slow, staggered, eased. Resting state is visible; the keyframe
     runs from hidden, with fill-mode backwards so there's no flash. Under
     prefers-reduced-motion the global reset collapses it to an instant show. */
  .hero__statement,
  .hero__intro,
  .hero__meta {
    animation: hero-rise var(--duration-slow) var(--ease-out) backwards;
  }
  .hero__statement { animation-delay: 40ms; }
  .hero__intro { animation-delay: 180ms; }
  .hero__meta { animation-delay: 320ms; }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(0.9rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
