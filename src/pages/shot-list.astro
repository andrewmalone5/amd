---
// The shot list — an owner-only inventory of every visual the case studies
// are waiting for, generated from the `needs` entries in the project data.
// Unlinked from navigation, noindexed, excluded from the sitemap. Each item
// links into its case study with ?shotlist so the slot shows in context.
import SiteLayout from '../layouts/SiteLayout.astro';
import { projects } from '../data/projects';
import { withBase } from '../lib/url';

const list = projects
  .map((p) => ({
    title: p.title,
    client: p.client,
    slug: p.slug,
    needs: p.blocks.flatMap((b) =>
      b.type === 'media' && !b.image && b.needs
        ? [{ label: b.label, kind: b.needs.kind, what: b.needs.what, caption: b.caption }]
        : []
    ),
  }))
  .filter((p) => p.needs.length > 0);

const total = list.reduce((n, p) => n + p.needs.length, 0);
---

<SiteLayout title="Shot list | Andrew Malone" description="Owner inventory of visuals to gather." minimalFooter noindex>
  <section class="shotlist column--wide">
    <h1 class="ghost-head">Shot List</h1>
    <p class="shotlist__intro">
      {total} visuals to gather across {list.length} case studies. Each one already has a
      designed slot waiting in its story &mdash; open a case with the link to see the slot in
      context. When an asset is ready, set its <code>image</code> path in
      <code>src/data/projects.ts</code> and the spec card is replaced by the real thing.
    </p>

    {list.map((p) => (
      <section class="proj">
        <h2 class="proj__title">
          {p.title}
          <a class="proj__go" href={withBase(`/work/${p.slug}?shotlist=1`)}>See slots in context<span aria-hidden="true">&nbsp;&rarr;</span></a>
        </h2>
        <ol class="needs">
          {p.needs.map((n) => (
            <li class="item">
              <p class="item__kind">{n.kind}</p>
              <p class="item__label">{n.label}</p>
              <p class="item__what">{n.what}</p>
              {n.caption && <p class="item__caption">Planned caption: &ldquo;{n.caption}&rdquo;</p>}
            </li>
          ))}
        </ol>
      </section>
    ))}
  </section>
</SiteLayout>

<style>
  .shotlist {
    padding-block: var(--section-tight) var(--section);
  }
  .shotlist__intro {
    margin-top: var(--space-lg);
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink-muted);
    max-width: 56ch;
  }
  .shotlist__intro code {
    font-size: 0.85em;
    color: var(--color-ink);
  }

  .proj {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
  }
  .proj__title {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    flex-wrap: wrap;
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
  }
  .proj__go {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    border-bottom: 1px solid var(--color-link-underline);
    padding-bottom: 2px;
    white-space: nowrap;
  }

  .needs {
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-md);
  }
  .item {
    border: 1.5px dashed var(--color-hairline-strong);
    border-radius: var(--radius-frame);
    padding: var(--space-md) var(--space-lg);
  }
  .item__kind {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-mark);
  }
  .item__label {
    margin-top: var(--space-3xs);
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: var(--leading-tight);
  }
  .item__what {
    margin-top: var(--space-xs);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-ink-muted);
  }
  .item__caption {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
</style>
