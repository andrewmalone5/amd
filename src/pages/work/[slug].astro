---
// The case-study template. One route, every project. The page is composed from
// the project's `blocks` array, so a two-sentence project and the anchor share
// the same template but render at completely different densities.
//
// A content grid keeps text at a readable measure while media breaks out wider.
// Spacing varies by block type, so the rhythm reads as edited rather than gridded.
import SiteLayout from '../../layouts/SiteLayout.astro';
import DealsSliver from '../../components/case/DealsSliver.astro';
import BetweenVisits from '../../components/case/BetweenVisits.astro';
import PayoutTimeline from '../../components/case/PayoutTimeline.astro';
import AdoptionCurve from '../../components/case/AdoptionCurve.astro';
import { projects } from '../../data/projects';
import { withBase } from '../../lib/url';
import { imgDims } from '../../lib/img';
import { showAssetSlots } from '../../config';

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
---

<SiteLayout title={`${project.title} | Andrew Malone`} description={project.summary} minimalFooter>
  <article class:list={['case', { 'case--slots': showAssetSlots }]}>
    <a class="case__back" href={withBase('/#work')}>&larr;&nbsp;&nbsp;Selected Work</a>

    <header class="case__header">
      <p class="eyebrow">
        {project.num} / {project.client} / {project.discipline} / {project.year}
      </p>
      <h1 class="case__title" transition:name={`title-${project.slug}`}>{project.title}</h1>
      {project.status && <span class="tag case__status">{project.status}</span>}
    </header>

    {project.blocks.map((b) =>
      b.type === 'heading' ? (
        <header class="block block--heading">
          {b.kicker && <p class="eyebrow">{b.kicker}</p>}
          <h2>{b.text}</h2>
        </header>
      ) : b.type === 'narrative' ? (
        <div class="block block--narrative">
          {b.body.split('\n\n').map((para) => (
            <p>{para}</p>
          ))}
        </div>
      ) : b.type === 'quote' ? (
        <blockquote class="block block--quote">
          <p>{b.text}</p>
          {b.cite && <cite>{b.cite}</cite>}
        </blockquote>
      ) : b.type === 'ledger' ? (
        <section class="block block--ledger">
          {b.kicker && <p class="eyebrow">{b.kicker}</p>}
          <p class="ledger__rule">{b.rule}</p>
          <div class="ledger__grid">
            <div class="ledger__row ledger__row--head">
              <p>Never</p>
              <p>Instead</p>
            </div>
            {b.rows.map((r) => (
              <div class="ledger__row">
                <p class="ledger__never">{r.never}</p>
                <p class="ledger__instead">{r.instead}</p>
              </div>
            ))}
          </div>
        </section>
      ) : b.type === 'stat' ? (
        <div class="block block--stat">
          <span class="stat__value">{b.value}</span>
          <span class="stat__label">{b.label}</span>
        </div>
      ) : b.type === 'media' ? (
        /* No image yet → nothing on the public page, unless showAssetSlots
           (src/config.ts) keeps the spec card visible in the page flow during
           the build-out. Shot-list mode (?shotlist, owner-only) shows the same
           card regardless of the flag. */
        b.image ? (
          <figure class="block block--media">
            <div class:list={['media__frame', 'media__frame--image', { 'media__frame--tall': !b.full && (imgDims(b.image).height ?? 0) > (imgDims(b.image).width ?? 1) * 1.15 }]}>
              <img src={withBase(b.image)} alt={b.label} loading="lazy" decoding="async" {...imgDims(b.image)} />
            </div>
            {b.caption && <figcaption>{b.caption}</figcaption>}
          </figure>
        ) : b.needs ? (
          <figure class="block block--media block--need">
            <div class="need">
              <p class="need__kind">{b.needs.kind}</p>
              <p class="need__label">{b.label}</p>
              <p class="need__what">{b.needs.what}</p>
              {b.caption && <p class="need__caption">Planned caption: &ldquo;{b.caption}&rdquo;</p>}
            </div>
          </figure>
        ) : null
      ) : b.type === 'overview' ? (
        <div class="block block--overview">
          <dl class="overview__cols">
            {b.columns.map((c) => (
              <div class="overview__col">
                <dt>{c.label}</dt>
                <dd>{c.value}</dd>
              </div>
            ))}
          </dl>
          <p class="overview__body"><span class="overview__lead">The one-minute version.</span> {b.body}</p>
        </div>
      ) : b.type === 'statRow' ? (
        <dl class="block block--statrow" data-count={b.stats.length}>
          {b.stats.map((s) => (
            <div class="statrow__item">
              <dd>{s.value}</dd>
              <dt>{s.label}</dt>
            </div>
          ))}
        </dl>
      ) : b.type === 'callout' ? (
        <aside class="block block--callout">
          <p class="eyebrow">{b.kicker}</p>
          {b.body.split('\n\n').map((para) => (
            <p class="callout__body">{para}</p>
          ))}
        </aside>
      ) : b.type === 'principle' ? (
        <section class="block block--principle">
          <span class="principle__num" aria-hidden="true">{b.num}</span>
          <div class="principle__content">
            <h3>{b.title}</h3>
            {b.body.split('\n\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>
        </section>
      ) : b.type === 'duo' ? (
        b.items.some((item) => item.image) ? (
          <div class:list={['block', 'block--duo', { 'block--duo-lead': b.lead }]}>
            {b.lead && (
              <div class="duo__lead">
                {b.lead.split('\n\n').map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            )}
            {b.items.filter((item) => item.image).map((item) => (
              <figure class="duo__item">
                <div class="duo__frame">
                  <img src={withBase(item.image)} alt={item.label} loading="lazy" decoding="async" {...imgDims(item.image)} />
                </div>
                {item.caption && <figcaption>{item.caption}</figcaption>}
              </figure>
            ))}
          </div>
        ) : null
      ) : b.type === 'artifact' ? (
        b.name === 'deals-sliver' ? <DealsSliver /> : b.name === 'care-between-visits' ? <BetweenVisits /> : b.name === 'payout-timeline' ? <PayoutTimeline /> : b.name === 'adoption-curve' ? <AdoptionCurve /> : null
      ) : b.type === 'pairs' ? (
        <div class="block block--pairs">
          {b.kicker && <p class="eyebrow pairs__kicker">{b.kicker}</p>}
          <dl class="pairs__grid">
            {b.items.map((item) => (
              <div class="pairs__row">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      ) : null
    )}
  </article>
</SiteLayout>

<style>
  /* Content grid: a readable centre column, with room to break media out wider.
     Everything defaults to the centre column; media and nav opt into the width.
     The left track is sized to centre the 61rem hanging envelope (the width the
     wide blocks share), not the prose column — otherwise the right-hanging
     blocks push the composition off page centre. 61rem must stay in sync with
     the hanging blocks' width below. */
  .case {
    display: grid;
    grid-template-columns:
      minmax(var(--page-gutter), calc((100% - 61rem) / 2))
      min(42rem, calc(100% - 2 * var(--page-gutter)))
      minmax(var(--page-gutter), 1fr);
    padding-block: var(--space-2xl) var(--section);
  }
  .case > * {
    grid-column: 2;
  }

  /* One shared left axis: header and structural blocks start at the prose
     column's left edge and extend right. Only media breaks out centred. */
  .case > .case__back,
  .case > .case__header {
    grid-column: 2 / -1;
  }

  .case__back {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .case__back:hover { color: var(--color-ink); }

  /* Header — the case title is Display LG (one step below the homepage hero). */
  .case__header {
    margin-top: var(--space-xl);
    animation: case-rise var(--duration-slow) var(--ease-out) backwards;
  }
  .case__title {
    font-size: var(--text-display-lg);
    max-width: 18ch;
    margin-top: var(--space-md);
  }
  .case__status { margin-top: var(--space-lg); }

  @keyframes case-rise {
    from { opacity: 0; transform: translateY(0.75rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Block rhythm — default gap between blocks, with emphasis blocks given more
     air. This is where density stops being uniform. */
  .block + .block { margin-top: var(--space-xl); }
  .block--quote,
  .block--stat { margin-top: var(--section-tight); margin-bottom: var(--space-lg); }
  .block--media { margin-top: var(--section); margin-bottom: var(--space-lg); }
  .case__header + .block { margin-top: var(--section-tight); }

  /* Section heading — a kicker plus a Spectral h2, opened by a hairline. These
     are what give a long case study its arc. */
  .block--heading {
    margin-top: var(--section);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-hairline);
  }
  .block--heading .eyebrow {
    margin-bottom: var(--space-sm);
  }
  .block--heading h2 {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    max-width: 24ch;
  }
  .block--heading + .block { margin-top: var(--space-lg); }

  /* Narrative */
  .block--narrative p {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
  }
  .block--narrative p + p {
    margin-top: var(--space-md);
  }

  /* Pull quote — Spectral, marked with a short rule above it. */
  .block--quote {
    padding-top: var(--space-lg);
    border-top: 2px solid var(--color-mark); /* R2: emphasis opens in the second ink */
  }
  .block--quote p {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
    text-wrap: balance;
  }
  .block--quote cite {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  /* Ledger — a governing copy rule proved by evidence. The rule opens in the
     quote's emphasis language (second-ink rule, Spectral), then a Never/Instead
     table shows the forbidden phrasing struck out against what shipped. */
  .case > .block--ledger {
    grid-column: 2 / -1;
    width: min(61rem, calc(100% - var(--page-gutter)));
    margin-top: var(--section-tight);
    margin-bottom: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 2px solid var(--color-mark);
  }
  .block--ledger .eyebrow { margin-bottom: var(--space-sm); }
  .ledger__rule {
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
    text-wrap: balance;
    max-width: 40ch;
  }
  .ledger__grid { margin-top: var(--space-xl); }
  .ledger__row {
    display: grid;
    grid-template-columns: minmax(0, 18rem) 1fr;
    gap: var(--space-xl);
    padding-block: var(--space-sm);
    border-top: 1px solid var(--color-hairline);
  }
  .ledger__row--head {
    border-top: none;
    padding-bottom: var(--space-2xs);
  }
  .ledger__row--head p {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .ledger__never {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-ink-faint);
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }
  .ledger__instead {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
  }
  @media (max-width: 40rem) {
    .ledger__row { grid-template-columns: 1fr; gap: var(--space-3xs); }
    .ledger__row--head p + p { display: none; }
  }

  /* Stat — a single big number. Reads as a lead when a project opens on it. */
  .block--stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .stat__value {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    line-height: 1;
    letter-spacing: var(--tracking-display);
    color: var(--color-mark); /* R2: measured outcomes take the second ink */
  }
  .stat__label {
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
    max-width: 28ch;
  }

  /* Media — the imposing moment. Breaks out well past the text column, close
     to full-bleed, so the work dominates when it appears. The embed slot for
     live React prototypes (client:load) or images. */
  .case > .block--media {
    grid-column: 1 / -1;
    justify-self: center;
    width: min(88rem, calc(100% - 2 * var(--page-gutter)));
  }
  .media__frame {
    aspect-ratio: 16 / 9;
    display: grid;
    place-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-frame);
  }
  /* A real image drops the panel entirely: the shot fills the breakout at
     natural height, separated from the page by a crisp hairline edge and a
     soft lift rather than a mat frame. */
  .media__frame--image {
    aspect-ratio: auto;
    display: block;
    background: none;
    border: none;
    border-radius: 0;
    padding: 0;
  }
  .media__frame--image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-frame);
    border: 1px solid var(--color-hairline);
    box-shadow:
      0 1px 2px rgba(28, 25, 18, 0.05),
      0 32px 64px -40px rgba(28, 25, 18, 0.28);
  }
  /* Dialog-shaped shots (clearly taller than wide) centre at a readable width
     instead of stretching across the breakout. Same edge treatment. */
  .media__frame--tall img {
    width: auto;
    max-width: 100%;
    max-height: 46rem;
    margin-inline: auto;
  }
  .block--media figcaption {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-align: center;
  }

  /* Shot-list cards: hidden from visitors, shown when the owner loads any
     page with ?shotlist — or everywhere while the pre-launch showAssetSlots
     flag is on. Dashed frame so a needed asset can never be mistaken for a
     finished one. */
  .block--need { display: none; }
  :global([data-shotlist]) .block--need,
  .case--slots .block--need { display: block; }
  .need {
    border: 1.5px dashed var(--color-hairline-strong);
    border-radius: var(--radius-frame);
    padding: var(--space-lg) var(--space-xl);
    max-width: 46rem;
    margin-inline: auto;
  }
  .need__kind {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-mark);
  }
  .need__label {
    margin-top: var(--space-2xs);
    font-family: var(--font-display);
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
  }
  .need__what {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 58ch;
  }
  .need__caption {
    margin-top: var(--space-sm);
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  /* Overview — the at-a-glance strip under the case header. The metadata runs
     as one colophon row across the full width, so uneven values stop tearing
     the grid; the one-minute version sits beneath at the prose measure. */
  .case > .block--overview {
    grid-column: 2 / -1;
    width: min(61rem, calc(100% - var(--page-gutter)));
    margin-top: var(--section-tight);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
  }
  .overview__cols {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-lg) var(--space-xl);
  }
  .overview__col dt {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .overview__col dd {
    margin: var(--space-3xs) 0 0;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    line-height: 1.4;
  }
  .overview__body {
    margin-top: var(--space-xl);
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
    max-width: 58ch;
  }
  .overview__lead {
    font-weight: var(--weight-semibold);
  }
  @media (max-width: 48rem) {
    .overview__cols { grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  }

  /* Stat row — 2-4 stats sharing one ruled row. */
  .case > .block--statrow {
    grid-column: 2 / -1;
    width: min(61rem, calc(100% - var(--page-gutter)));
    margin-block: var(--section-tight) var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 2px solid var(--color-mark); /* R2 */
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--space-lg) var(--space-xl);
  }
  .statrow__item dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-display-md);
    line-height: 1;
    letter-spacing: var(--tracking-display);
    color: var(--color-mark); /* R2 */
  }
  .statrow__item dt {
    margin-top: var(--space-xs);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-muted);
    max-width: 24ch;
    line-height: 1.5;
  }

  /* Callout — an aside set in the serif, indented off the prose axis. No box,
     no border: the register change is the container. */
  .block--callout {
    padding-left: var(--space-md);
  }
  /* The callout cites its source in the same serif voice it speaks in —
     an italic note, not another tracked-caps label in the page's rhythm. */
  .block--callout .eyebrow {
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-tight);
    text-transform: none;
    color: var(--color-ink-muted);
  }
  .callout__body {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    line-height: 1.55;
    letter-spacing: var(--tracking-tight);
    color: var(--color-ink);
  }
  .callout__body + .callout__body { margin-top: var(--space-sm); }

  /* Principle — oversized numeral + display title. The old portfolio's
     strongest pattern, rebuilt in the site's type. */
  .case > .block--principle {
    grid-column: 2 / -1;
    width: min(61rem, calc(100% - var(--page-gutter)));
    margin-top: var(--section);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-hairline);
    display: grid;
    grid-template-columns: minmax(0, 14rem) minmax(0, 42rem);
    gap: var(--space-lg) var(--space-2xl);
  }
  .principle__num {
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 4vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: var(--tracking-display);
    color: var(--color-ink-faint);
  }
  .principle__content h3 {
    font-size: var(--text-display-sm);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    max-width: 24ch;
  }
  .principle__content p {
    margin-top: var(--space-md);
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
  }
  /* Same-specificity selector as the base rule, or the collapse never wins. */
  @media (max-width: 48rem) {
    .case > .block--principle { grid-template-columns: 1fr; gap: var(--space-sm); }
    .principle__num { font-size: 3.5rem; }
  }

  /* Duo — two images side by side, sharing the media breakout. */
  .case > .block--duo {
    grid-column: 1 / -1;
    justify-self: center;
    width: min(88rem, calc(100% - 2 * var(--page-gutter)));
    margin-top: var(--section);
    margin-bottom: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    align-items: start;
  }
  /* Duo items share the bare treatment: no panel, edge and lift on the shot. */
  .duo__frame {
    display: flex;
    justify-content: center;
  }
  .duo__frame img {
    display: block;
    max-width: 100%;
    max-height: 42rem;
    width: auto;
    height: auto;
    border-radius: var(--radius-frame);
    border: 1px solid var(--color-hairline);
    box-shadow:
      0 1px 2px rgba(28, 25, 18, 0.05),
      0 32px 64px -40px rgba(28, 25, 18, 0.28);
  }
  .block--duo figcaption {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-align: center;
  }
  @media (max-width: 48rem) {
    .case > .block--duo { grid-template-columns: 1fr; }
  }

  /* Duo with a lead: the text column sits in the same row as the two slender
     drawers, so the argument and the screens it describes read together. The
     drawer tracks are sized to the shots; the prose takes the rest. */
  .case > .block--duo-lead {
    grid-template-columns: minmax(0, 1fr) minmax(0, 21rem) minmax(0, 21rem);
    gap: var(--space-lg) var(--space-xl);
    align-items: center;
  }
  .duo__lead p {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-ink);
  }
  .duo__lead p + p { margin-top: var(--space-md); }
